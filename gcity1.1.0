<!DOCTYPE html><html lang="pt-br"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"><title>GEOMETRY CITY - V1.0.1</title><style>
* { box-sizing: border-box; }
body, html { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #050510; position: fixed; }
canvas { display: block; width: 100vw; height: 100vh; object-fit: contain; }
#coin-display { position: absolute; top: env(safe-area-inset-top, 20px); left: 20px; color: #f1c40f; font-size: 24px; z-index: 2000; font-weight: bold; text-shadow: 2px 2px #000; }
#ui-top { position: absolute; top: 15px; width: 100%; display: flex; flex-direction: column; align-items: center; opacity: 0; z-index: 10; }
#progress-container { width: 60%; height: 10px; background: rgba(255,255,255,0.2); border: 1px solid #fff; border-radius: 5px; overflow: hidden; }
#progress-bar { width: 0%; height: 100%; background: #00ffcc; }
.overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 1500; color: white; }
.icon-btn { width: 70px; height: 70px; background: #34495e; border: 3px solid #fff; border-radius: 15px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 30px; margin: 10px; }
</style></head><body>
<div id="coin-display">💰 <span id="coins">0</span></div>
<div id="ui-top"><div id="percentage" style="color:#fff; font-size:20px;">0%</div><div id="progress-container"><div id="progress-bar"></div></div></div>
<div id="menu" class="overlay">
    <h1 style="color:#00ffcc; font-size: 35px; margin: 0;">GEOMETRY CITY</h1>
    <p style="color: #aaa; font-size: 14px;">V1.0.1 OFFICIAL</p>
    <div style="display:flex;">
        <div onclick="startGame()" class="icon-btn" style="background:#2ecc71">▶️</div>
    </div>
</div>
<canvas id="game"></canvas>
<script>
const canvas = document.getElementById('game'), ctx = canvas.getContext('2d');
let totalCoins=0, gameRunning=false, score=0;
let player = { x: 80, y: 0, vy: 0, rotation: 0, onGround: false };
function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
window.addEventListener('resize', resize); resize();
function loadGame() { totalCoins = parseInt(localStorage.getItem('gc_coins')) || 0; document.getElementById('coins').innerText = totalCoins; }
function startGame() { 
    document.getElementById('menu').style.display='none'; 
    document.getElementById('ui-top').style.opacity='1';
    player.y = canvas.height - 150; gameRunning=true; loop(); 
}
function update() {
    if(!gameRunning) return;
    player.vy += 1.4; player.y += player.vy;
    if(player.y > canvas.height - 150) { player.y = canvas.height - 150; player.vy = 0; player.onGround = true; player.rotation = Math.round(player.rotation/90)*90; }
    else { player.onGround = false; player.rotation += 8; }
}
function draw() {
    ctx.fillStyle="#050510"; ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.fillStyle="black"; ctx.fillRect(0, canvas.height-100, canvas.width, 100);
    ctx.save(); ctx.translate(player.x+25, player.y+25); ctx.rotate(player.rotation*Math.PI/180);
    ctx.fillStyle="#00ffcc"; ctx.fillRect(-25,-25,50,50); ctx.strokeStyle="white"; ctx.strokeRect(-25,-25,50,50); ctx.restore();
}
function loop() { update(); draw(); if(gameRunning) requestAnimationFrame(loop); }
window.addEventListener('touchstart', () => { if(player.onGround) player.vy = -18; });
loadGame();
</script></body></html>
